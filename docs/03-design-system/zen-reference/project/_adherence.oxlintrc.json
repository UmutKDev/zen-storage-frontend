        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute > JSXIdentifier[name!=/^(?:wordmark|size|className|key|ref|className|style|children)$/]",
        "message": "<Logo> doesn't accept that prop. Declared props: wordmark, size, className."
