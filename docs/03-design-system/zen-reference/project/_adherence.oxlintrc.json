        "selector": "JSXOpeningElement[name.name='MenuItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|description|kbd|disabled|danger|onSelect|key|ref|className|style|children)$/]",
        "message": "<MenuItem> doesn't accept that prop. Declared props: icon, label, description, kbd, disabled, danger, onSelect."
      },
      {
        "selector": "JSXOpeningElement[name.name='DocumentFormat'] > JSXAttribute > JSXIdentifier[name!=/^(?:ext|label|key|ref|className|style|children)$/]",
        "message": "<DocumentFormat> doesn't accept that prop. Declared props: ext, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='NewFolderDialog'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|onClose|destination|onCreate|initialName|initialEncrypted|initialHidden|key|ref|className|style|children)$/]",
        "message": "<NewFolderDialog> doesn't accept that prop. Declared props: open, onClose, destination, onCreate, initialName, initialEncrypted, initialHidden."
      },
      {
        "selector": "JSXOpeningElement[name.name='Skeleton'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|style|key|ref|className|style|children)$/]",
        "message": "<Skeleton> doesn't accept that prop. Declared props: className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SmartGrid'] > JSXAttribute > JSXIdentifier[name!=/^(?:rowHeight|gap|children|style|key|ref|className|style|children)$/]",
        "message": "<SmartGrid> doesn't accept that prop. Declared props: rowHeight, gap, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|defaultChecked|onCheckedChange|disabled|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, defaultChecked, onCheckedChange, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tabs'] > JSXAttribute > JSXIdentifier[name!=/^(?:tabs|value|defaultValue|onValueChange|variant|key|ref|className|style|children)$/]",
        "message": "<Tabs> doesn't accept that prop. Declared props: tabs, value, defaultValue, onValueChange, variant."
      },
