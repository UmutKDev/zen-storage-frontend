        "message": "<Toast> variant must be one of 'success' | 'error' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='UnlockDialog'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|onClose|variant|name|verify|onUnlock|hint|key|ref|className|style|children)$/]",
        "message": "<UnlockDialog> doesn't accept that prop. Declared props: open, onClose, variant, name, verify, onUnlock, hint."
      },
      {
        "selector": "JSXOpeningElement[name.name='UnlockDialog'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:folder|hidden)$/]",
        "message": "<UnlockDialog> variant must be one of 'folder' | 'hidden'."
      },
      {
        "selector": "JSXOpeningElement[name.name='UploadQueueItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|kind|size|count|progress|status|key|ref|className|style|children)$/]",
        "message": "<UploadQueueItem> doesn't accept that prop. Declared props: name, kind, size, count, progress, status."
      },
      {
        "selector": "JSXOpeningElement[name.name='UploadQueueItem'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:file|folder)$/]",
        "message": "<UploadQueueItem> kind must be one of 'file' | 'folder'."
      },
      {
        "selector": "JSXOpeningElement[name.name='UploadQueueItem'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:encrypting|uploading|done)$/]",
        "message": "<UploadQueueItem> status must be one of 'encrypting' | 'uploading' | 'done'."
      },
      {
        "selector": "JSXOpeningElement[name.name='UsageBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:used|max|label|key|ref|className|style|children)$/]",
        "message": "<UsageBar> doesn't accept that prop. Declared props: used, max, label."
      }
    ]
