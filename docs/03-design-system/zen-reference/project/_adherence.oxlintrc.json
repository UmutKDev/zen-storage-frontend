{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/storage/**",
              "components/surfaces/**",
              "ui_kits/zen-storage-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Geist|Geist Mono))/i]",
        "message": "Font not provided by the design system. Available: Geist, Geist Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='ArchiveFormat'] > JSXAttribute > JSXIdentifier[name!=/^(?:ext|label|key|ref|className|style|children)$/]",
        "message": "<ArchiveFormat> doesn't accept that prop. Declared props: ext, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|alt|initials|size|className|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, alt, initials, size, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|default|lg)$/]",
        "message": "<Avatar> size must be one of 'sm' | 'default' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|secondary|destructive|success|warning|info|outline)$/]",
        "message": "<Badge> variant must be one of 'default' | 'secondary' | 'destructive' | 'success' | 'warning' | 'info' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Breadcrumb'] > JSXAttribute > JSXIdentifier[name!=/^(?:segments|onNavigate|rootLabel|key|ref|className|style|children)$/]",
        "message": "<Breadcrumb> doesn't accept that prop. Declared props: segments, onNavigate, rootLabel."
      },
      {
        "selector": "JSXOpeningElement[name.name='BulkActionBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:count|allSelected|canDownload|onSelectAll|onMove|onArchive|onExtract|onDownload|onDelete|onClear|key|ref|className|style|children)$/]",
        "message": "<BulkActionBar> doesn't accept that prop. Declared props: count, allSelected, canDownload, onSelectAll, onMove, onArchive, onExtract, onDownload, onDelete, onClear."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|upload|secondary|outline|ghost|ghost-destructive|destructive|link)$/]",
        "message": "<Button> variant must be one of 'primary' | 'upload' | 'secondary' | 'outline' | 'ghost' | 'ghost-destructive' | 'destructive' | 'link'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:xs|sm|default|lg|icon|icon-sm|icon-xs)$/]",
        "message": "<Button> size must be one of 'xs' | 'sm' | 'default' | 'lg' | 'icon' | 'icon-sm' | 'icon-xs'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|description|children|className|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: title, description, children, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|defaultChecked|onCheckedChange|disabled|className|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, defaultChecked, onCheckedChange, disabled, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Dialog'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|onClose|title|description|children|footer|maxWidth|key|ref|className|style|children)$/]",
        "message": "<Dialog> doesn't accept that prop. Declared props: open, onClose, title, description, children, footer, maxWidth."
      },
      {
        "selector": "JSXOpeningElement[name.name='ExtractArchiveItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|key|ref|className|style|children)$/]",
        "message": "<ExtractArchiveItem> doesn't accept that prop. Declared props: name, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='FileCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|kind|size|childCount|encrypted|hidden|locked|selected|selecting|dropTarget|onOpen|onToggleSelect|onAction|style|key|ref|className|style|children)$/]",
        "message": "<FileCard> doesn't accept that prop. Declared props: name, kind, size, childCount, encrypted, hidden, locked, selected, selecting, dropTarget, onOpen, onToggleSelect, onAction, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FileCard'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:dir|file)$/]",
        "message": "<FileCard> kind must be one of 'dir' | 'file'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FileRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|kind|size|modified|childCount|encrypted|hidden|locked|selected|selecting|dropTarget|task|onOpen|onToggleSelect|onAction|onDownload|key|ref|className|style|children)$/]",
        "message": "<FileRow> doesn't accept that prop. Declared props: name, kind, size, modified, childCount, encrypted, hidden, locked, selected, selecting, dropTarget, task, onOpen, onToggleSelect, onAction, onDownload."
      },
      {
        "selector": "JSXOpeningElement[name.name='FileRow'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:dir|file)$/]",
        "message": "<FileRow> kind must be one of 'dir' | 'file'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FileTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|kind|thumb|ratio|size|childCount|duration|encrypted|hidden|locked|selected|selecting|onOpen|onToggleSelect|onAction|style|key|ref|className|style|children)$/]",
        "message": "<FileTile> doesn't accept that prop. Declared props: name, kind, thumb, ratio, size, childCount, duration, encrypted, hidden, locked, selected, selecting, onOpen, onToggleSelect, onAction, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FileTile'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:dir|file)$/]",
        "message": "<FileTile> kind must be one of 'dir' | 'file'."
      },
      {
        "selector": "JSXOpeningElement[name.name='GlassPanel'] > JSXAttribute > JSXIdentifier[name!=/^(?:tier|as|className|style|children|key|ref|className|style|children)$/]",
        "message": "<GlassPanel> doesn't accept that prop. Declared props: tier, as, className, style, children."
